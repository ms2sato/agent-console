[Unit]
Description=Agent Console Server (Multi-User)
After=network.target

[Service]
Type=simple
User={{SERVICE_USER}}
Group={{SERVICE_GROUP}}
UMask=0002
WorkingDirectory={{HOME}}/agent-console
ExecStart={{BUN_PATH}} run start
Restart=on-failure
RestartSec=5

Environment=PATH={{HOME}}/.bun/bin:/usr/local/bin:/usr/bin:/bin
Environment=AUTH_MODE=multi-user
Environment=AGENT_CONSOLE_HOME={{DATA_ROOT}}
Environment=PORT={{PORT}}
Environment=HOST=0.0.0.0
Environment=NODE_ENV=production
Environment=AUTH_COOKIE_SECURE={{AUTH_COOKIE_SECURE}}
# PTY_PROVIDER_BLOCK_PLACEHOLDER

[Install]
WantedBy=multi-user.target
